#!/bin/bash
set -e

if [ ! -f client/dist/index.html ] || [ ! -f server/dist/server.js ]; then
  echo "Prebuilt application files are missing. Pull the latest main branch before deploying."
  exit 1
fi

# Frontend and TypeScript builds are produced before deployment. Keep the small host runtime-only.
rm -rf client/node_modules server/node_modules
npm ci --omit=dev --no-audit --no-fund
