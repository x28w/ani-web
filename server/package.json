{
  "name": "ani-web-server",
  "version": "1.7.1",
  "type": "commonjs",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --max-old-space-size=256 dist/server.js",
    "dev": "nodemon --watch \"src/**/*.ts\" --exec \"ts-node --transpile-only src/server.ts --dev\"",
    "build": "tsc",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "overrides": {
    "encoding-sniffer": "^1.0.2",
    "glob": "^13.0.0"
  }
}
